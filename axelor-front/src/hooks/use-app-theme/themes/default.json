{
  "palette": {
    "mode": "light",
    "blue": "#2196f3",
    "indigo": "#3f51b5",
    "purple": "#9c27b0",
    "pink": "#e91e63",
    "red": "#f44336",
    "orange": "#ff9800",
    "yellow": "#ffeb3b",
    "green": "#4caf50",
    "teal": "#009688",
    "cyan": "#00bcd4",
    "white": "#ffffff",
    "black": "#000000",
    "gray": "#9e9e9e",
    "gray_dark": "#424242",
    "gray_100": "#f5f5f5",
    "gray_200": "#eeeeee",
    "gray_300": "#e0e0e0",
    "gray_400": "#bdbdbd",
    "gray_500": "#9e9e9e",
    "gray_600": "#757575",
    "gray_700": "#616161",
    "gray_800": "#424242",
    "gray_900": "#212121",
    "body_bg": "#ffffff",
    "body_color": "#001136",
    "secondary_bg": "#eff2f9",
    "secondary_color": "#002d92",
    "tertiary_bg": "#f2f4f8",
    "tertiary_color": "#001d5f",
    "emphasis_color": "#001136",
    "primary": "#155dfc",
    "secondary": "#001d5f",
    "success": "#4caf50",
    "warning": "#ff9800",
    "danger": "#f44336",
    "info": "#2196f3",
    "light": "#f2f4f8",
    "dark": "#212121"
  },
  "border": {
    "color": "#c5d4f4"
  },
  "typography": {},
  "components": {
    "Shell": {
      "view": {
        "toolbar": {
          "gap": "0.25rem",
          "padding": "0.25rem",
          "border": {
            "color": "var(--bs-border-color)",
            "style": "solid",
            "width": "1px"
          }
        },
        "content": {
          "padding": "0"
        }
      }
    },
    "Panel": {
      "header": {
        "bg": "#c5d4f4",
        "border": {
          "width": 0
        }
      },
      "title": {
        "padding": "0.25rem 0.5rem"
      }
    },
    "Dropdown": {
      "border": {
        "color": "#8aacf7"
      },
      "item_hover": {
        "bg": "#eff2f9"
      },
      "item_active": {
        "bg": "primary",
        "color": "#fff"
      },
      "divider": {
        "bg": "#8aacf7"
      }
    },
    "NavMenu": {
      "bg": "#eff2f9",
      "border": {
        "radius": "1rem"
      },
      "item": {
        "border": {
          "radius": "1rem"
        }
      },
      "header": {
        "padding": "0.5rem"
      },
      "item_hover": {
        "bg": "var(--bs-primary-bg-subtle)"
      },
      "item_active": {
        "bg": "rgba(var(--bs-primary-rgb), 0.8)",
        "color": "white"
      },
      "icon": {
        "bg": "transparent"
      },
      "icon_hover": {
        "bg": "transparent"
      },
      "icon_active": {
        "color": "white"
      },
      "buttons": {
        "bg": "transparent"
      }
    },
    "NavTabs": {
      "item": {
        "padding": "0.25rem 0.5rem"
      },
      "text": {
        "transform": "none"
      },
      "icon": {
        "bg": "transparent"
      },
      "icon_hover": {
        "bg": "transparent"
      },
      "icon_active": {
        "bg": "transparent"
      }
    },
    "CommandBar": {
      "button": {
        "padding": "0.35rem 0.45rem",
        "border": {
          "radius": 0
        }
      },
      "button_hover": {
        "bg": "#c5d4f4"
      },
      "button_active": {
        "bg": "#8aacf7"
      }
    },
    "Table": {
      "bg": "#f2f4f8",
      "border": {
        "color": "#c5d4f4"
      },
      "header": {
        "bg": "#eff2f9"
      },
      "row_odd": {
        "bg": "#dee5f5"
      },
      "row_hover": {
        "bg": "#a9c1f7"
      },
      "row_active": {
        "bg": "#8aacf7"
      },
      "cell_active": {
        "bg": "#6996f9"
      },
      "cell": {
        "padding": "0.375rem 0.5rem"
      }
    },
    "Button": {
      "paddingX": "0.5rem",
      "paddingY": "0.25rem"
    },
    "Badge": {
      "padding": "0.25rem 0.5rem",
      "border": {
        "radius": "1rem"
      }
    },
    "Form": {
      "padding": "1rem",
      "gap": "0.5rem 0.75rem"
    },
    "Input": {
      "padding": "calc(0.25rem + 1px) 0 0.25rem 0",
      "focus": {
        "shadow": "none",
        "border_width": "0 0 1px 0"
      },
      "invalid_focus": {
        "shadow": "none",
        "border_width": "0 0 1px 0"
      },
      "placeholder": {
        "color": "var(--bs-tertiary-color)"
      },
      "invalid": {
        "border_width": "0 0 1px 0"
      },
      "border": {
        "radius": 0
      },
      "border_width": "0 0 1px 0"
    }
  }
}